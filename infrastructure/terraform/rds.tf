# EconomicBridge — RDS PostgreSQL 16 with PostGIS.
#
# Multi-AZ in production (var.rds_multi_az), single-AZ in dev. Storage
# autoscales up to var.rds_max_storage_gb. Password generated by Terraform
# (see secrets.tf) and pulled directly from the random_password resource —
# Terraform owns the lifecycle end-to-end, so we don't fetch from Secrets
# Manager here (would create a circular dependency).
#
# Why PostgreSQL 16: PostGIS 3.6 (used in local dev) is shipped via the
# `rds.force_ssl` parameter set and the `postgis` extension. AWS supports
# PostGIS 3.4 on PG16, which is API-compatible with our 3.6 dev install.
#
# CLAUDE.md §3 mentions PostgreSQL 15 — we upgraded to 16 during local
# dev because PG15 had a PostGIS install path that wouldn't work on
# Windows. PG16 has the same SQL surface for our usage.

# ─── DB subnet group ───────────────────────────────────────────────────
# RDS must live in private subnets. The subnet group lists the AZs RDS
# can fail over into.

resource "aws_db_subnet_group" "main" {
  name        = "${local.name_prefix}-rds-subnets"
  description = "Private subnets for RDS PostgreSQL"
  subnet_ids  = aws_subnet.private[*].id

  tags = {
    Name = "${local.name_prefix}-rds-subnets"
  }
}

# ─── Parameter group ───────────────────────────────────────────────────
# Custom PG16 parameter group so we can:
#   - preload PostGIS at startup (shared_preload_libraries)
#   - log slow queries (anything > 1s)
#   - force SSL connections (CLAUDE.md §4.1)

resource "aws_db_parameter_group" "postgres16" {
  name        = "${local.name_prefix}-pg16"
  family      = "postgres16"
  description = "PostgreSQL 16 parameters tuned for EconomicBridge"

  parameter {
    name         = "shared_preload_libraries"
    value        = "pg_stat_statements"
    apply_method = "pending-reboot"
  }

  parameter {
    name  = "log_min_duration_statement"
    value = "1000" # ms — log anything slower than 1 second
  }

  parameter {
    name  = "log_connections"
    value = "1"
  }

  parameter {
    name  = "log_disconnections"
    value = "1"
  }

  # Force TLS — non-SSL clients are rejected at the wire level.
  parameter {
    name  = "rds.force_ssl"
    value = "1"
  }

  tags = {
    Name = "${local.name_prefix}-pg16-params"
  }
}

# ─── RDS instance ──────────────────────────────────────────────────────

resource "aws_db_instance" "main" {
  identifier = "${local.name_prefix}-postgres"

  engine = "postgres"
  # Major version only — AWS retires specific minors (16.4 no longer exists),
  # so a pinned minor rots. RDS picks the current 16.x; lifecycle ignores the
  # resulting drift (auto-minor-version-upgrade).
  engine_version = "16"
  instance_class       = var.rds_instance_class
  parameter_group_name = aws_db_parameter_group.postgres16.name

  # Storage — gp3 by default, autoscaling enabled
  allocated_storage     = var.rds_allocated_storage_gb
  max_allocated_storage = var.rds_max_storage_gb
  storage_type          = "gp3"
  storage_encrypted     = true
  kms_key_id            = null # default AWS-managed KMS key for RDS

  db_name  = "economicbridge"
  username = "ebadmin"
  # NB: pulled from the random_password resource, NOT from Secrets Manager.
  # Terraform owns this secret's lifecycle. The same value is written to
  # Secrets Manager (see secrets.tf) for runtime consumers (ECS task defs).
  password = random_password.rds.result

  # Networking — private subnets only, only ECS tasks may reach 5432
  db_subnet_group_name   = aws_db_subnet_group.main.name
  vpc_security_group_ids = [aws_security_group.rds.id]
  publicly_accessible    = false
  port                   = 5432

  # HA + backups
  multi_az                = var.rds_multi_az
  backup_retention_period = var.rds_backup_retention_days
  backup_window           = "02:00-03:00" # UTC — off-peak for af-south-1
  maintenance_window      = "sun:03:30-sun:04:30"
  copy_tags_to_snapshot   = true

  # Observability
  performance_insights_enabled          = true
  performance_insights_retention_period = 7 # free tier
  monitoring_interval                   = 60
  monitoring_role_arn                   = aws_iam_role.rds_monitoring.arn
  enabled_cloudwatch_logs_exports       = ["postgresql", "upgrade"]

  # Safety rails
  deletion_protection       = var.rds_deletion_protection
  skip_final_snapshot       = var.environment != "production"
  final_snapshot_identifier = var.environment == "production" ? "${local.name_prefix}-final-${formatdate("YYYYMMDD-hhmmss", timestamp())}" : null
  apply_immediately         = var.environment != "production"

  # Force-recreate triggers — most are stable, but lifecycle prevents
  # unnecessary churn if AWS auto-bumps the patch version.
  lifecycle {
    ignore_changes = [
      engine_version,           # allow auto-minor-version-upgrade
      final_snapshot_identifier # contains timestamp() which changes every plan
    ]
  }

  tags = {
    Name = "${local.name_prefix}-rds"
  }

  # Wait for the password secret version to be written first so the
  # secret string in Secrets Manager and the RDS password stay in sync.
  depends_on = [
    aws_secretsmanager_secret_version.rds_password,
    aws_iam_role_policy_attachment.rds_monitoring,
  ]
}
