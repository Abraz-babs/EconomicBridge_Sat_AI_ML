# EconomicBridge — env template (COMMITTED to git, no real values).
# Copy to `.env` at the same path and fill in real values. `.env` is gitignored.
#
# Loaded by:
#   - apps/api/config.py            (pydantic-settings → ../.env)
#   - apps/ingestion/config.py      (pydantic-settings → ../.env)
#   - apps/ml/config.py             (pydantic-settings → ../.env)
#   - apps/frontend/next.config.ts  (dotenv → ../../.env)
#
# Maps to CLAUDE.md §3 (tech stack) and §8 (satellite + comms providers).
# Production secrets live in AWS Secrets Manager, NOT in env vars — see §4.1.

# ─────────────────────────────────────────────────────────────────────
# COMMON
# ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────
# DATABASE  (PostgreSQL 15+ with PostGIS; TimescaleDB optional)
# ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:devpassword@localhost:5432/economicbridge
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:devpassword@localhost:5432/economicbridge
DB_ECHO=false
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10

# Redis — required by Celery (apps/ingestion task queue). Optional until Step 8.1.
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ─────────────────────────────────────────────────────────────────────
# FRONTEND  (NEXT_PUBLIC_* are baked into the browser bundle at build time)
# ─────────────────────────────────────────────────────────────────────
# Free public Mapbox token at https://account.mapbox.com/access-tokens/
# Must start with `pk.` — never use a secret `sk.` token here.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_public_mapbox_token_here
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ─────────────────────────────────────────────────────────────────────
# SATELLITE — NASA FIRMS  (fire/heat detection, MODIS + VIIRS)
# ─────────────────────────────────────────────────────────────────────
# Free 32-char MAP_KEY from: https://firms.modaps.eosdis.nasa.gov/api/area/
# Without a key the ingestion service falls back to mock data in dev.
NASA_FIRMS_MAP_KEY=
NASA_FIRMS_BASE_URL=https://firms.modaps.eosdis.nasa.gov/api
NASA_FIRMS_DEFAULT_SOURCE=MODIS_NRT

# ─────────────────────────────────────────────────────────────────────
# SATELLITE — NASA Earthdata / VIIRS Black Marble  (nightlight)
# ─────────────────────────────────────────────────────────────────────
# Free Bearer token from https://urs.earthdata.nasa.gov/ → Generate Token.
# Drives Module 01 (Economic Visibility) — LAADS DAAC catalog calls for
# VNP46A2 nightlight granules. Empty token → catalog returns [] and the
# ingest task tags rows source='worldpop_v1' or 'seed_v1' instead.
# Production: token comes from AWS Secrets Manager, never env vars.
EARTHDATA_TOKEN=
EARTHDATA_LAADS_BASE_URL=https://ladsweb.modaps.eosdis.nasa.gov
VIIRS_BLACK_MARBLE_PRODUCT=VNP46A2   # VNP46A2 daily | VNP46A4 annual composite

# ─────────────────────────────────────────────────────────────────────
# POPULATION — WorldPop  (anonymous catalog)
# ─────────────────────────────────────────────────────────────────────
# Open REST catalog at worldpop.org/rest/data — no auth. Raster reads
# (Phase B) hit s3://worldpop-data with anonymous boto3.
WORLDPOP_REST_BASE_URL=https://hub.worldpop.org/rest/data
WORLDPOP_DEFAULT_DATASET=pop/pic      # pop/pic = per-country populations; pop/wpgp = 100m global
WORLDPOP_DEFAULT_YEAR=2024            # WorldPop publishes ~2y behind

# ─────────────────────────────────────────────────────────────────────
# SATELLITE — Copernicus Sentinel Hub  (Sentinel-1 SAR + Sentinel-2 MSI)
# ─────────────────────────────────────────────────────────────────────
# CDSE (Copernicus Data Space Ecosystem) — Sentinel Hub on CDSE, NOT
# commercial Sentinel Hub. Register at:
#   https://dataspace.copernicus.eu/  (free)
# Create an OAuth client with `client_credentials` grant. The `sh-` prefix
# on client IDs is NOT a signal of which system to target — only successful
# OAuth at the identity.dataspace endpoint confirms it (slice 13a memory).
# Endpoints are pinned in apps/ingestion/config.py — no base-url override.
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
SENTINEL1_COLLECTION=sentinel-1-grd
SENTINEL2_COLLECTION=sentinel-2-l2a

# ─────────────────────────────────────────────────────────────────────
# SATELLITE — N2YO  (live satellite pass tracking → drives ingestion cron)
# ─────────────────────────────────────────────────────────────────────
# Free API key at https://www.n2yo.com/api/
# Step 8.3 — N2YO pass-event polling determines when to call FIRMS/Copernicus
# for each tenant ROI.
N2YO_API_KEY=
N2YO_BASE_URL=https://api.n2yo.com/rest/v1/satellite
SENTINEL1_NORAD_ID=43591   # Sentinel-1B
SENTINEL2_NORAD_ID=40697   # Sentinel-2A

# ─────────────────────────────────────────────────────────────────────
# SATELLITE — Google Earth Engine  (preprocessing pipelines: NDVI, SAR composites)
# ─────────────────────────────────────────────────────────────────────
# Provision a Google Cloud service account with Earth Engine API enabled at:
#   https://developers.google.com/earth-engine/guides/service_account
# Step 11 — CropGuard NDVI time-series and SAR despeckling.
GEE_SERVICE_ACCOUNT=service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=./secrets/gee-service-account.json
GEE_PROJECT_ID=

# ─────────────────────────────────────────────────────────────────────
# AI / ML — Anthropic Claude  (natural-language alert summarisation)
# ─────────────────────────────────────────────────────────────────────
# Step 12 — summarise active alert clusters for the operator review panel.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────────────────────────────
# COMMS — Termii  (Nigerian SMS gateway, free-tier farmer alerts)
# ─────────────────────────────────────────────────────────────────────
# Step 10 — SMS dispatch when conflict predictor → HIGH confidence band.
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com/api
TERMII_SENDER_ID=EconoBridge

# ─────────────────────────────────────────────────────────────────────
# COMMS — Twilio  (international SMS for ECOWAS tenants)
# ─────────────────────────────────────────────────────────────────────
# Used for Ghana, Senegal, and other Francophone/international pilots
# where Termii does not deliver.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
