# EconomicBridge — Environment Variables
# =========================================
# NEVER commit a .env file with real values to git.
# This file documents every required variable.
# In production, all secrets are loaded from AWS Secrets Manager.
# In local development, copy this file to .env and fill in values.
# Run: cp .env.example .env

# ─────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────
APP_ENV=development                          # development | staging | production
APP_NAME=EconomicBridge
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true                               # MUST be false in production
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                              # json | text (use json in production)
SECRET_KEY=                                  # 64-char random string — run: openssl rand -hex 32

# ─────────────────────────────────────────
# DATABASE — PostgreSQL
# ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://economicbridge:password@localhost:5432/economicbridge
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
# Admin connection (for migrations and tenant provisioning only)
DATABASE_ADMIN_URL=postgresql://postgres:password@localhost:5432/economicbridge

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300                          # Default cache TTL in seconds
REDIS_ALERT_CHANNEL=economicbridge:alerts    # Pub/sub channel for live alerts

# ─────────────────────────────────────────
# JWT AUTHENTICATION
# ─────────────────────────────────────────
JWT_SECRET_KEY=                              # 64-char random string — DIFFERENT from SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15          # DO NOT increase — security requirement
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────
# AWS
# ─────────────────────────────────────────
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=                           # Use IAM roles in production — not keys
AWS_SECRET_ACCESS_KEY=                       # Use IAM roles in production — not keys
AWS_S3_BUCKET=economicbridge-satellite
AWS_S3_RAW_PREFIX=raw/
AWS_S3_PROCESSED_PREFIX=processed/
AWS_SECRETS_MANAGER_PREFIX=/economicbridge/production/
# CloudWatch
AWS_CLOUDWATCH_LOG_GROUP=/economicbridge/application
AWS_CLOUDWATCH_LOG_STREAM=api

# ─────────────────────────────────────────
# SATELLITE — COPERNICUS / SENTINEL HUB
# ─────────────────────────────────────────
COPERNICUS_CLIENT_ID=                        # From Copernicus Data Space Ecosystem
COPERNICUS_CLIENT_SECRET=                    # From Copernicus Data Space Ecosystem
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
COPERNICUS_API_URL=https://sh.dataspace.copernicus.eu
COPERNICUS_CATALOG_URL=https://catalogue.dataspace.copernicus.eu/odata/v1
SENTINEL1_COLLECTION=sentinel-1-grd
SENTINEL2_COLLECTION=sentinel-2-l2a

# ─────────────────────────────────────────
# SATELLITE — NASA FIRMS
# ─────────────────────────────────────────
NASA_FIRMS_MAP_KEY=                                                          # 32-char MAP_KEY from https://firms.modaps.eosdis.nasa.gov/api/ — keep in apps/ingestion/.env (gitignored)
NASA_FIRMS_BASE_URL=https://firms.modaps.eosdis.nasa.gov/api/area/csv
NASA_FIRMS_PRODUCT=VIIRS_NOAA20_NRT         # Primary heat detection product

# ─────────────────────────────────────────
# SATELLITE — N2YO (Live Pass Tracking)
# ─────────────────────────────────────────
N2YO_API_KEY=                               # Register at n2yo.com/api
N2YO_BASE_URL=https://api.n2yo.com/rest/v1/satellite
SENTINEL1_NORAD_ID=43591                    # Sentinel-1B NORAD catalog number
SENTINEL2_NORAD_ID=40697                    # Sentinel-2A NORAD catalog number

# ─────────────────────────────────────────
# GOOGLE EARTH ENGINE
# ─────────────────────────────────────────
GEE_SERVICE_ACCOUNT=                        # service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=./secrets/gee-service-account.json  # NEVER commit this file
GEE_PROJECT_ID=                             # Google Cloud project ID

# ─────────────────────────────────────────
# AI / ML — ANTHROPIC (CLAUDE API)
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=                          # For natural language alert summarisation
ANTHROPIC_MODEL=claude-opus-4-5             # Model for alert generation
ANTHROPIC_MAX_TOKENS=500                    # Keep short — alerts only
ANTHROPIC_ALERT_LANGUAGES=en,fr,ha,yo,ig,pt

# ─────────────────────────────────────────
# SMS / NOTIFICATIONS
# ─────────────────────────────────────────
# Termii (primary — Nigerian numbers)
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com/api
TERMII_SENDER_ID=EconomicBridge
# Twilio (fallback — international)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAPBOX_TOKEN=                   # Public token — safe to expose in frontend
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SENTRY_DSN=                     # Optional in development

# ─────────────────────────────────────────
# MONITORING & OBSERVABILITY
# ─────────────────────────────────────────
SENTRY_DSN=                                 # Backend Sentry DSN
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1              # 10% in production
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ─────────────────────────────────────────
# INGESTION SERVICE
# ─────────────────────────────────────────
INGESTION_SERVICE_URL=http://localhost:8001  # Internal — not exposed externally
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_MAX_TASKS_PER_CHILD=1000             # Prevents memory leaks in long-running workers

# ─────────────────────────────────────────
# ML SERVICE
# ─────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8002         # Internal — not exposed externally
MODEL_ARTIFACTS_PATH=./models/artifacts/
CONFLICT_MODEL_VERSION=1.2.0                # From Citadel Kebbi deployment
FLOOD_MODEL_VERSION=1.0.0
CROP_MODEL_VERSION=1.1.0
POVERTY_MODEL_VERSION=1.0.0
ML_CONFIDENCE_THRESHOLD_HIGH=0.90
ML_CONFIDENCE_THRESHOLD_MEDIUM=0.75
ML_HUMAN_REVIEW_REQUIRED_BELOW=0.75

# ─────────────────────────────────────────
# RATE LIMITING (Kong Gateway)
# ─────────────────────────────────────────
RATE_LIMIT_PUBLIC_API=100                   # Requests per hour for free tier
RATE_LIMIT_INSTITUTIONAL=10000              # Requests per hour for paid tier
RATE_LIMIT_ADMIN=1000                       # Requests per hour for admin

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
# Comma-separated list — no wildcards in production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────
FEATURE_FARMLAND_PROTECTION=true
FEATURE_CROPGUARD=true
FEATURE_SHOCKGUARD=true
FEATURE_MOBILITY_COMPASS=false              # Not yet built
FEATURE_SKILLSBRIDGE=false                  # Not yet built
FEATURE_ECOWAS_EXPANSION=false             # Phase 2
FEATURE_PUBLIC_API=false                    # Phase 3
