# EconomicBridge — Satellite Ingestion service local env
# Copy to .env. `.env` is gitignored.

APP_ENV=development
LOG_LEVEL=INFO

# Database — must match apps/api's DATABASE_URL so both services see the same DB
DATABASE_URL=postgresql+asyncpg://postgres:devpassword@localhost:5432/economicbridge

# NASA FIRMS — free MAP_KEY registration at:
#   https://firms.modaps.eosdis.nasa.gov/api/area/
# Leave unset to enable mock-mode (returns canned dev data, no network call).
# NASA_FIRMS_MAP_KEY=

# CORS allowlist (rarely needed — this service is server-to-server only)
CORS_ORIGINS=["http://localhost:3000"]
