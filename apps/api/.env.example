# EconomicBridge API — local environment variables
# Copy to `.env` and adjust as needed. `.env` is gitignored.

APP_ENV=development
LOG_LEVEL=INFO

# CORS allowlist for the dashboard frontend
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:devpassword@localhost:5432/economicbridge
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:devpassword@localhost:5432/economicbridge
DB_ECHO=false
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10

# JWT settings will be added when authentication is reintroduced for paid tier endpoints.
