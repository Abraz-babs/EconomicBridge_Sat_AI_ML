# EconomicBridge — Docker Compose env template.
#
# Copy to `.env.docker` and source it before `docker compose up`, or
# rename to `.env` if you're running compose-only. Compose already reads
# `.env` automatically from the same directory as the compose file.
#
# Variables that affect runtime (read by the Python services) are loaded
# via the `env_file: [.env]` directive in docker-compose.yml. Variables
# that affect the FRONTEND BUILD (NEXT_PUBLIC_*) must be present in the
# host shell when you run `docker compose build`, because they're passed
# as `build.args` and inlined into the client bundle.

# ─────────────────────────────────────────────────────────────────────
# Compose-only overrides
# ─────────────────────────────────────────────────────────────────────
# Postgres superuser password — used by the db service AND by the
# DATABASE_URL string injected into every Python service.
DB_PASSWORD=devpassword

# ─────────────────────────────────────────────────────────────────────
# Frontend build-time vars (must be set BEFORE `docker compose build`)
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ─────────────────────────────────────────────────────────────────────
# Everything else (NASA FIRMS, Termii, Twilio, Anthropic …) is read
# straight from the existing `.env` at the repo root. See `.env.example`
# for the full list of supported variables. The Python services pick
# them up via `env_file: [.env]` in docker-compose.yml.
# ─────────────────────────────────────────────────────────────────────
